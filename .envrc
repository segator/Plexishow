#!/usr/bin/env bash
# direnv: automatically install and activate mise tools on directory enter

# Load local .env if it exists (for DAGGER_CLOUD_TOKEN, etc.)
if [ -f .env ]; then
    dotenv .env
fi

# Auto-install missing tools and activate environment
if has mise; then
    mise install
    eval "$(mise activate bash)"
elif has asdf; then
    asdf install
else
    echo "⚠  WARNING: Neither mise nor asdf found. Install tools manually."
    echo "   brew install mise"
fi

# Warn if DAGGER_CLOUD_TOKEN is not set (cache won't be shared)
if [ -z "${DAGGER_CLOUD_TOKEN:-}" ]; then
    echo "ℹ  DAGGER_CLOUD_TOKEN not set. Dagger cache won't be shared."
    echo "   Copy .env.example to .env and add your token from https://dagger.io/cloud"
fi
